{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>codesphere-cloud/renovate-config:go-config"],
  "packageRules": [
    {
      "matchPackageNames": ["*"],
      "postUpgradeTasks": {
          "commands": [
            "go tool go-licenses report --template .NOTICE.template ./... > NOTICE",
            "go generate ./..."
          ]
      }
    }
  ]
}

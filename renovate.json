{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>codesphere-cloud/renovate-config:go-config"],
  "packageRules": [
    {
      "matchPackageNames": ["*"],
      "postUpgradeTasks": {
          "commands": [
            "go mod tidy",
            "make generate-notice",
            "go generate ./..."
          ]
      }
    }
  ]
}
